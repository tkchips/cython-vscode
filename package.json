{
  "name": "cython-vscode",
  "displayName": "cython-vscode",
  "description": "Cython semantic highlighting powered by tree-sitter-cython",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.119.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:cython",
    "onCommand:cython-vscode.refreshParse",
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "cython-vscode.refreshParse",
        "title": "Cython: Refresh Parse"
      },
      {
        "command": "cython-vscode.showLog",
        "title": "Cython: Show Extension Log"
      }
    ],
    "languages": [
      {
        "id": "cython",
        "aliases": [
          "Cython",
          "cython"
        ],
        "extensions": [
          ".pyx",
          ".pxd",
          ".pxi"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "configuration": {
      "title": "cython-vscode",
      "properties": {
        "cython-vscode.treeSitterCythonRoot": {
          "type": "string",
          "default": "/home/tkc/workspace/tree-sitter-cython",
          "description": "Absolute path to the tree-sitter-cython repository root used for parser and highlights query."
        },
        "cython-vscode.enableHoverDebug": {
          "type": "boolean",
          "default": false,
          "description": "Show tree-sitter parse node info on hover (debug feature)."
        }
      }
    },
    "configurationDefaults": {
      "[cython]": {
        "editor.semanticHighlighting.enabled": true
      }
    },
    "menus": {
      "editor/context": [
        {
          "command": "cython-vscode.refreshParse",
          "when": "editorTextFocus && resourceLangId == cython",
          "group": "navigation@99"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.19",
    "@types/vscode": "^1.120.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "node-gyp-build": "^4.8.4",
    "tree-sitter": "^0.25.0"
  }
}
